# Procurement Agent — Environment Variables
# Copy this to .env.local and fill in your values.

# MongoDB connection string (required)
MONGODB_URI=mongodb://admin:admin123@localhost:27017/procurement?authSource=admin

# Redis URL for job queue (optional, defaults to localhost)
REDIS_URL=redis://localhost:6379

# Anthropic API key for Claude AI features (required)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Playwright concurrency — max browser contexts open simultaneously (optional)
BROWSER_MAX_CONTEXTS=3

# Vendor search concurrency — max vendors searched in parallel (optional)
VENDOR_MAX_CONCURRENCY=4

# Authentication (required) — single admin user gates the entire app
AUTH_EMAIL=admin@thetechio.com
# bcrypt hash of the password. Default below is for "@dm1n".
# To change: node -e "require('bcryptjs').hash('NEW_PASSWORD',10).then(console.log)"
AUTH_PASSWORD_HASH=$2b$10$0bVWVkhjnThUyTKlbqhxuuoS89bSFjqI2UFJ2tzQ4pO4PjgoOhuZy
# Random 32+ char string used to sign session JWTs.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-characters-long
